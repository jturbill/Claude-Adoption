# Supabase — find these in Project Settings > API in your Supabase dashboard.
# The "anon" (public) key is safe to expose to the browser. The service role key
# is NOT and must never be committed or prefixed with NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — used only by server-side code (admin actions, thumbnail uploads).
# Keep this SECRET. Set it in Vercel as an Environment Variable, not in public config.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public site metadata (optional but recommended).
NEXT_PUBLIC_SITE_URL=https://deborahjaynedesigns.com
NEXT_PUBLIC_CONTACT_EMAIL=hello@deborahjaynedesigns.com
